{
    "name": "newspapershub",
    "version": "1.0.0",
    "description": "Professional newspaper PDF generator",
    "author": "CodeKonix",
    "license": "MIT",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.codekonix.newspapershub",
        "productName": "NewsPapersHub",
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Utility",
            "icon": "icons"
        },
        "files": [
            "main.js",
            "preload.js",
            "splash.html",
            "error.html",
            "web/**"
        ],
        "extraResources": [
            {
                "from": "bin/",
                "to": "bin/",
                "filter": [
                    "**/*"
                ]
            }
        ]
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0"
    }
}